# Anthropic API key — enables the live AI quiz and the chat tutor.
# Get one at https://console.anthropic.com/
# Without it the site still works fully; the quiz/chat panels just show a
# "set your key" message instead of generating content.
ANTHROPIC_API_KEY=

# Optional — override the model used for the quiz + tutor.
# Default is claude-opus-4-7. For faster / cheaper responses you can use:
#   ANTHROPIC_MODEL=claude-haiku-4-5
#   ANTHROPIC_MODEL=claude-sonnet-4-6
# ANTHROPIC_MODEL=claude-opus-4-7
